{
  "manifest_version": 3,
  "name": "glowficlog",
  "version": "0.1.6",
  "description": "Reformats glowfic.com threads into a compact, high-information-density reader view.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "*://glowfic.com/posts/*",
        "*://www.glowfic.com/posts/*",
        "*://glowfic.com/replies/*",
        "*://www.glowfic.com/replies/*"
      ],
      "js": ["content.js"],
      "css": ["reader.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["options.html"],
      "matches": ["*://glowfic.com/*", "*://www.glowfic.com/*"],
      "use_dynamic_url": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "glowficlog@beshir.org",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "128.0"
    }
  }
}
